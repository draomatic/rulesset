# ---------- 规则 ----------
rules:
  # 1. 禁用 QUIC
  - AND,((NETWORK,UDP),(DST-PORT,443)),REJECT

  # 2. 局域网直连
  - DOMAIN-SUFFIX,local,DIRECT
  - IP-CIDR,127.0.0.0/8,DIRECT,no-resolve
  - IP-CIDR,172.16.0.0/12,DIRECT,no-resolve
  - IP-CIDR,192.168.0.0/16,DIRECT,no-resolve
  - IP-CIDR,10.0.0.0/8,DIRECT,no-resolve

  # 3. AI 服务关键字兜底
  - DOMAIN-KEYWORD,openai,🤖 AI 服务
  - DOMAIN-KEYWORD,chatgpt,🤖 AI 服务
  - DOMAIN-KEYWORD,anthropic,🤖 AI 服务
  - DOMAIN-KEYWORD,claude,🤖 AI 服务
  - DOMAIN-KEYWORD,grok,🤖 AI 服务
  - DOMAIN-SUFFIX,x.ai,🤖 AI 服务
  - DOMAIN-SUFFIX,perplexity.ai,🤖 AI 服务
  - DOMAIN-SUFFIX,pplx.ai,🤖 AI 服务

  # 4. 广告/隐私/劫持拦截
  - RULE-SET,RejectGlobal,🛡️ 广告拦截
  - RULE-SET,RejectChina,🛡️ 广告拦截
  - RULE-SET,Privacy,🛡️ 广告拦截
  - RULE-SET,Hijacking,🛡️ 广告拦截

  # 5. 应用分流
  - RULE-SET,OpenAI,🤖 AI 服务
  - RULE-SET,Claude,🤖 AI 服务
  - RULE-SET,YouTube,📹 YouTube
  - RULE-SET,Telegram,📲 Telegram
  - RULE-SET,Streaming,📺 国际媒体
  - RULE-SET,Apple,🍎 Apple
  - RULE-SET,Google,🌍 Google
  - RULE-SET,Proxy,🚀 节点选择

  # 6. 国内直连
  - RULE-SET,ChinaDomain,DIRECT
  - RULE-SET,ChinaIP,DIRECT
  - GEOIP,CN,DIRECT

  # 7. 兜底
  - MATCH,🐟 漏网之鱼
