mode: rule
log-level: info
allow-lan: true
mixed-port: 7890
ipv6: false
unified-delay: true
tcp-concurrent: true
external-controller: 127.0.0.1:9090
find-process-mode: strict

# ---------- 流量嗅探 ----------
sniffer:
  enable: true
  force-dns-mapping: true
  parse-pure-ip: true
  override-destination: true
  sniff:
    HTTP:
      ports: [80, 8080-8880]
      override-destination: true
    TLS:
      ports: [443, 8443]
    QUIC:
      ports: [443, 8443]
  skip-domain:
    - "+.push.apple.com"
    - "+.apple.com"

# ---------- DNS 配置 ----------
dns:
  enable: true
  ipv6: false
  prefer-h3: false
  respect-rules: true
  use-hosts: true
  use-system-hosts: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter:
    - "*.lan"
    - "*.local"
    - "+.msftconnecttest.com"
    - "+.msftncsi.com"
    - "localhost.ptlogin2.qq.com"
    - "+.srv.nintendo.net"
    - "+.stun.playstation.net"
    - "+.xboxlive.com"
    - "*.battlenet.com"
    - "*.battlenet.com.cn"
    - "+.wotgame.cn"
    - "+.wggames.cn"
    - "+.wowsgame.cn"
    - "+.wargaming.net"
    - "*.magic.stellaglowco.com"
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
  nameserver:
    - https://dns.alidns.com/dns-query
    - https://doh.pub/dns-query
  proxy-server-nameserver:
    - https://dns.alidns.com/dns-query
    - https://doh.pub/dns-query
  fallback:
    - https://1.1.1.1/dns-query
    - https://dns.google/dns-query

  nameserver-policy:
    "geosite:gfw,geolocation-!cn":
      - https://1.1.1.1/dns-query
      - https://dns.google/dns-query
    "+.google.com,+.facebook.com,+.youtube.com,+.twitter.com,+.x.com,+.openai.com,+.anthropic.com,+.grok.com,+.x.ai":
      - https://1.1.1.1/dns-query
      - https://dns.google/dns-query
  fallback-filter:
    geoip: true
    geoip-code: CN
    ipcidr:
      - 240.0.0.0/4
      - 0.0.0.0/32

# ---------- Hosts ----------
hosts:
  'dns.google': 0.0.0.0
  'cloudflare-dns.com': 0.0.0.0
  'mozilla.cloudflare-dns.com': 0.0.0.0
  'dns.quad9.net': 0.0.0.0

# ---------- 代理分组 ----------
proxy-groups:
  - name: "🚀 节点选择"
    type: select
    include-all: true
    proxies:
      - "♻️ 自动选择"
      - "🎯 故障转移"
      - "🔯 手动选择"
      - "DIRECT"

  - name: "♻️ 自动选择"
    type: url-test
    include-all: true
    url: https://www.gstatic.com/generate_204
    interval: 300
    tolerance: 50
    lazy: true

  - name: "🎯 故障转移"
    type: fallback
    include-all: true
    url: https://www.gstatic.com/generate_204
    interval: 300

  - name: "🔯 手动选择"
    type: select
    include-all: true

  - name: "🤖 AI 服务"
    type: select
    include-all: true
    proxies:
      - "🚀 节点选择"
      - "♻️ 自动选择"
      - "DIRECT"

  - name: "📺 国际媒体"
    type: select
    include-all: true
    proxies:
      - "🚀 节点选择"
      - "♻️ 自动选择"
      - "DIRECT"

  - name: "📹 YouTube"
    type: select
    include-all: true
    proxies:
      - "🚀 节点选择"
      - "♻️ 自动选择"
      - "DIRECT"

  - name: "📲 Telegram"
    type: select
    include-all: true
    proxies:
      - "🚀 节点选择"
      - "♻️ 自动选择"
      - "DIRECT"

  - name: "🍎 Apple"
    type: select
    include-all: true
    proxies:
      - "DIRECT"
      - "🚀 节点选择"

  - name: "🌍 Google"
    type: select
    include-all: true
    proxies:
      - "🚀 节点选择"
      - "DIRECT"

  - name: "🛡️ 广告拦截"
    type: select
    proxies:
      - "REJECT"
      - "DIRECT"

  - name: "🐟 漏网之鱼"
    type: select
    include-all: true
    proxies:
      - "🚀 节点选择"
      - "DIRECT"

